# Copy to .env.local and fill in to enable the real Spotify OAuth (PKCE) flow.
# Leave BLANK / omit the file entirely to run in demo mode with mock data.

VITE_SPOTIFY_CLIENT_ID=
# Optional. Defaults to <origin>/ — must EXACTLY match a Redirect URI
# registered in your Spotify app dashboard (e.g. http://127.0.0.1:5173/).
VITE_SPOTIFY_REDIRECT_URI=
